rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function me() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data
        : {};
    }

    function isAdmin() {
      return me().get("role", "") in ["super_admin", "admin_master"];
    }

    function myCampanha() {
      let d = me();
      return d.get("campanhaId", d.get("gabineteId", ""));
    }

    // Retorna true apenas quando o usuário tem uma campanha válida associada
    function hasCampanha() {
      return myCampanha() != "";
    }

    function camposProtegidosSelf() {
      return ["role", "campanhaId", "gabineteId", "assessorId",
              "coordenadorId", "criadoPor", "criadoEm"].toSet();
    }

    function camposProtegidosAssessor() {
      return ["role", "campanhaId", "gabineteId", "coordenadorId", "assessorId",
              "nome", "email", "telefone", "criadoPor", "criadoEm"].toSet();
    }

    function isAtivo() {
      return me().get("ativo", true) == true;
    }

    // Valida que userId pertence à mesma campanha (evita forjaria de notificação)
    function recipientInCampanha(userId) {
      let d = get(/databases/$(database)/documents/usuarios/$(userId)).data;
      return d.get("campanhaId", "") == myCampanha() ||
             d.get("gabineteId", "") == myCampanha();
    }

    // ─── campanhas ────────────────────────────────────────────────────────────
    match /campanhas/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.id == myCampanha() ||
        resource.data.get("parentGabineteId", "") == myCampanha()
      );
      allow write: if isAuth() && isAdmin();
    }

    // ─── usuarios ─────────────────────────────────────────────────────────────
    match /usuarios/{uid} {
      // get individual: restrito à própria campanha ou hierarquia direta
      allow get: if isAuth() && (
        request.auth.uid == uid ||
        isAdmin() ||
        resource.data.get("campanhaId", "") == myCampanha() ||
        resource.data.get("gabineteId", "") == myCampanha() ||
        resource.data.get("assessorId", "") == request.auth.uid ||
        resource.data.get("coordenadorId", "") == request.auth.uid
      );
      allow list: if isAuth() && (
        isAdmin() ||
        (hasCampanha() && resource.data.get("campanhaId", "") == myCampanha()) ||
        (hasCampanha() && resource.data.get("gabineteId", "") == myCampanha()) ||
        resource.data.get("assessorId", "") == request.auth.uid ||
        resource.data.get("coordenadorId", "") == request.auth.uid
      );
      allow create: if isAuth() && (
        isAdmin() ||
        // coordenador solicita colaborador pendente (aprovado via assessor/solicitacoes)
        (
          me().get("role", "") == "coordenador" &&
          request.resource.data.get("status", "") == "pendente" &&
          request.resource.data.get("coordenadorId", "") == request.auth.uid &&
          request.resource.data.get("campanhaId", "") == myCampanha()
        )
        // Criação de usuários Auth (assessor, coordenador, colaborador) ocorre server-side
        // via /api/admin/create-user usando Admin SDK — sem regra de client necessária.
      );
      allow update: if isAuth() && isAtivo() && (
        (request.auth.uid == uid &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(camposProtegidosSelf())) ||
        isAdmin() ||
        // assessor/AE só pode gerir coordenadores e colaboradores — nunca pares ou superiores
        (me().get("role", "") in ["assessor_executivo", "assessor"] &&
         resource.data.get("role", "") in ["coordenador", "colaborador"] && (
          resource.data.get("campanhaId", "") == myCampanha() ||
          resource.data.get("gabineteId", "") == myCampanha()
        ) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(camposProtegidosAssessor())) ||
        // coordenador corrigindo e reenviando própria solicitação recusada
        (
          me().get("role", "") == "coordenador" &&
          resource.data.get("status", "") == "recusado" &&
          resource.data.get("coordenadorId", "") == request.auth.uid &&
          request.resource.data.get("status", "") == "pendente" &&
          request.resource.data.get("coordenadorId", "") == request.auth.uid &&
          request.resource.data.get("campanhaId", "") == myCampanha()
        )
      );
      allow delete: if isAuth() && (
        isAdmin() ||
        // assessor_executivo: exclui assessores, coordenadores e colaboradores da própria campanha
        (
          me().get("role", "") == "assessor_executivo" &&
          resource.data.get("role", "") in ["assessor", "coordenador", "colaborador"] &&
          hasCampanha() &&
          (
            resource.data.get("campanhaId", "") == myCampanha() ||
            resource.data.get("gabineteId", "") == myCampanha()
          )
        ) ||
        // assessor: exclui coordenadores e colaboradores da própria campanha
        (
          me().get("role", "") == "assessor" &&
          resource.data.get("role", "") in ["coordenador", "colaborador"] &&
          (
            resource.data.get("campanhaId", "") == myCampanha() ||
            resource.data.get("gabineteId", "") == myCampanha()
          )
        ) ||
        // coordenador: exclui colaboradores que gerencia
        (
          me().get("role", "") == "coordenador" &&
          resource.data.get("role", "") == "colaborador" &&
          resource.data.get("coordenadorId", "") == request.auth.uid &&
          resource.data.get("campanhaId", "") == myCampanha()
        )
      );
    }

    // ─── eleitores (joia da coroa) ─────────────────────────────────────────────
    match /eleitores/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        // Executivo e Político: leem toda a campanha (requer campanha válida)
        (me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador"] &&
         hasCampanha() && resource.data.get("campanhaId", "") == myCampanha()) ||
        // Assessor: lê pelo assessorId (vínculo direto) OU pela campanha (fallback para dados sem assessorId)
        (me().get("role", "") == "assessor" &&
         hasCampanha() && resource.data.get("campanhaId", "") == myCampanha()) ||
        // Coordenador e colaborador: vínculo direto pelo ID
        resource.data.get("colaboradorId", "") == request.auth.uid ||
        resource.data.get("coordenadorId", "") == request.auth.uid
      );
      allow create: if isAuth() && (
        isAdmin() ||
        // colaborador cadastra para si mesmo
        (request.resource.data.get("campanhaId", "") == myCampanha() &&
         request.resource.data.get("colaboradorId", "") == request.auth.uid) ||
        // coordenador cadastra vinculando a colaborador da sua equipe
        (me().get("role", "") == "coordenador" &&
         request.resource.data.get("campanhaId", "") == myCampanha() &&
         request.resource.data.get("coordenadorId", "") == request.auth.uid &&
         request.resource.data.get("colaboradorId", "") != "") ||
        // assessor cadastra vinculando a colaborador da campanha
        (me().get("role", "") == "assessor" &&
         request.resource.data.get("campanhaId", "") == myCampanha() &&
         request.resource.data.get("colaboradorId", "") != "")
      );
      allow update: if isAuth() && isAtivo() && (
        isAdmin() ||
        (resource.data.get("campanhaId", "") == myCampanha() &&
         // Campos de vínculo territorial são imutáveis após criação
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(
           ["campanhaId", "colaboradorId", "coordenadorId", "assessorId", "criadoPor", "criadoEm"].toSet()
         ) && (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] ||
          resource.data.get("colaboradorId", "") == request.auth.uid ||
          resource.data.get("coordenadorId", "") == request.auth.uid
        ))
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── metas ────────────────────────────────────────────────────────────────
    match /metas/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("gabineteId", "") == myCampanha() ||
        resource.data.get("campanhaId", "") == myCampanha() ||
        resource.data.get("colaboradorId", "") == request.auth.uid ||
        resource.data.get("coordenadorId", "") == request.auth.uid
      );
      allow create, update: if isAuth() && (
        isAdmin() ||
        (me().get("role", "") in ["assessor_executivo", "assessor", "coordenador"] && (
          request.resource.data.get("gabineteId", "") == myCampanha() ||
          request.resource.data.get("campanhaId", "") == myCampanha()
        ))
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── candidatos ───────────────────────────────────────────────────────────
    match /candidatos/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("gabineteId", "") == myCampanha() ||
        resource.data.get("campanhaId", "") == myCampanha()
      );
      allow create, update: if isAuth() && (
        isAdmin() ||
        (me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
         request.resource.data.get("gabineteId", "") == myCampanha())
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── missoes ──────────────────────────────────────────────────────────────
    match /missoes/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("campanhaId", "") == myCampanha()
      );
      allow create: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo"] &&
          request.resource.data.get("campanhaId", "") == myCampanha() &&
          request.resource.data.get("campanhaId", "") != ""
        )
      );
      allow update: if isAuth() && isAtivo() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo"] &&
          resource.data.get("campanhaId", "") == myCampanha() &&
          // Campos de autoria e campanha são imutáveis
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(
            ["campanhaId", "criadoPorId", "criadoPorNome", "criadoEm"].toSet()
          )
        ) ||
        (
          me().get("role", "") == "assessor" &&
          resource.data.get("campanhaId", "") == myCampanha() &&
          resource.data.get("responsavelId", "") == request.auth.uid &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(
            ["campanhaId", "criadoPorId", "criadoPorNome", "criadoEm"].toSet()
          )
        )
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── determinacoes (Central de Comando Político — Sprint 20) ─────────────
    match /determinacoes/{id} {
      // Deputado lê as suas; AE lê as destinadas a ele
      allow read: if isAuth() && (
        isAdmin() ||
        (resource.data.get("campanhaId", "") == myCampanha() && (
          resource.data.get("criadoPorId", "")   == request.auth.uid ||
          resource.data.get("destinatarioId", "") == request.auth.uid
        ))
      );
      // Apenas o político (deputado) cria
      allow create: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") == "politico" &&
          hasCampanha() &&
          request.resource.data.get("campanhaId", "") == myCampanha() &&
          request.resource.data.get("criadoPorId", "") == request.auth.uid
        )
      );
      // AE atualiza apenas campos de execução — assunto/prazo/autoria/destinatário são imutáveis
      allow update: if isAuth() && isAtivo() && (
        isAdmin() ||
        (
          me().get("role", "") == "assessor_executivo" &&
          resource.data.get("campanhaId", "") == myCampanha() &&
          resource.data.get("destinatarioId", "") == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ["status", "aceitoEm", "aceitoPorId", "aceitoPorNome",
             "resultado", "conclusaoItems", "concluidoEm", "atualizadoEm", "missaoId"].toSet()
          )
        ) ||
        // Político pode vincular missão criada a partir da determinação
        (
          me().get("role", "") == "politico" &&
          resource.data.get("campanhaId", "") == myCampanha() &&
          resource.data.get("criadoPorId", "") == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(
            ["missaoId", "atualizadoEm"].toSet()
          )
        )
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── assessorias ──────────────────────────────────────────────────────────
    match /assessorias/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("campanhaId", "") == myCampanha()
      );
      allow create: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
          request.resource.data.get("campanhaId", "") == myCampanha() &&
          request.resource.data.get("campanhaId", "") != "" &&
          request.resource.data.get("criadoPor", "") == request.auth.uid
        )
      );
      allow update: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
          resource.data.get("campanhaId", "") == myCampanha()
        )
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── coordenacoes ─────────────────────────────────────────────────────────
    match /coordenacoes/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("campanhaId", "") == myCampanha()
      );
      allow create: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
          request.resource.data.get("campanhaId", "") == myCampanha() &&
          request.resource.data.get("campanhaId", "") != "" &&
          request.resource.data.get("criadoPor", "") == request.auth.uid
        )
      );
      allow update: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
          resource.data.get("campanhaId", "") == myCampanha()
        )
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── memoriaMandato ───────────────────────────────────────────────────────
    match /memoriaMandato/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("campanhaId", "") == myCampanha()
      );
      allow create: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
          request.resource.data.get("campanhaId", "") == myCampanha() &&
          request.resource.data.get("campanhaId", "") != ""
        )
      );
      allow update: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
          resource.data.get("campanhaId", "") == myCampanha() &&
          request.resource.data.get("campanhaId", "") == resource.data.get("campanhaId", "")
        )
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── atividades (log de auditoria) ────────────────────────────────────────
    match /atividades/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("gabineteId", "") == myCampanha() ||
        resource.data.get("campanhaId", "") == myCampanha()
      );
      allow create: if isAuth() && (
        request.resource.data.get("campanhaId", "") == myCampanha() ||
        request.resource.data.get("gabineteId", "") == myCampanha()
      );
      allow update, delete: if isAuth() && isAdmin();
    }

    // ─── coleções administrativas (prefixo _) ─────────────────────────────────

    // Rate limiting — acesso exclusivo via Admin SDK (server-side)
    // Deny explícito garante isolamento mesmo se regras globais mudarem
    match /_rate_limits/{id} {
      allow read, write: if false;
    }

    // Backups — acesso exclusivo via Admin SDK (server-side)
    match /_backups/{id} {
      allow read, write: if false;
    }

    // Manifesto de seeds (dados de teste) — exclusivo admin
    match /_seed_manifest/{id} {
      allow read, write: if isAuth() && isAdmin();
    }

    // Erros de runtime — gravados pelo ErrorBoundary client-side
    match /_erros/{id} {
      allow create: if isAuth();
      allow read, update, delete: if isAuth() && isAdmin();
    }

    // Solicitações de exclusão LGPD (Art. 18 — direito ao esquecimento)
    match /_solicitacoes_lgpd/{id} {
      allow create: if isAuth() && (
        isAdmin() ||
        (hasCampanha() && request.resource.data.get("campanhaId", "") == myCampanha())
      );
      allow read: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") == "assessor_executivo" &&
          hasCampanha() &&
          resource.data.get("campanhaId", "") == myCampanha()
        )
      );
      // Processamento LGPD: admin ou assessor_executivo da própria campanha
      allow update: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") == "assessor_executivo" &&
          hasCampanha() &&
          resource.data.get("campanhaId", "") == myCampanha()
        )
      );
      allow delete: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") == "assessor_executivo" &&
          hasCampanha() &&
          resource.data.get("campanhaId", "") == myCampanha()
        )
      );
    }

    // ── Notificações (Sprint 23) ────────────────────────────────────────────
    match /notificacoes/{id} {
      // Criação: usuário ativo com campanha válida. Tipo e destinatário obrigatórios.
      // O destinatário deve ser o próprio remetente ou um membro da mesma campanha.
      allow create: if isAuth() && isAtivo() &&
        hasCampanha() &&
        request.resource.data.get("campanhaId", "") == myCampanha() &&
        request.resource.data.get("campanhaId", "") != "" &&
        request.resource.data.get("usuarioId", "") != "" &&
        request.resource.data.get("tipo", "") in
          ["determinacao", "missao", "alerta", "meta", "prestacao", "sistema"] &&
        (
          request.resource.data.get("usuarioId", "") == request.auth.uid ||
          recipientInCampanha(request.resource.data.usuarioId)
        );
      // Só o destinatário lê, atualiza (marcar lida/arquivada) e deleta
      allow read, update, delete: if isAuth() && request.auth.uid == resource.data.usuarioId;
    }
  }
}
