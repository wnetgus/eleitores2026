rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function me() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data
        : {};
    }

    function isAdmin() {
      return me().get("role", "") in ["super_admin", "admin_master"];
    }

    function myCampanha() {
      let d = me();
      return d.get("campanhaId", d.get("gabineteId", ""));
    }

    function camposProtegidosSelf() {
      return ["role", "campanhaId", "gabineteId", "assessorId",
              "coordenadorId", "criadoPor", "criadoEm"].toSet();
    }

    function camposProtegidosAssessor() {
      return ["role", "campanhaId", "gabineteId", "coordenadorId"].toSet();
    }

    // ─── campanhas ────────────────────────────────────────────────────────────
    match /campanhas/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.id == myCampanha() ||
        resource.data.get("parentGabineteId", "") == myCampanha()
      );
      allow write: if isAuth() && isAdmin();
    }

    // ─── usuarios ─────────────────────────────────────────────────────────────
    match /usuarios/{uid} {
      // get individual: restrito à própria campanha ou hierarquia direta
      allow get: if isAuth() && (
        request.auth.uid == uid ||
        isAdmin() ||
        resource.data.get("campanhaId", "") == myCampanha() ||
        resource.data.get("gabineteId", "") == myCampanha() ||
        resource.data.get("assessorId", "") == request.auth.uid ||
        resource.data.get("coordenadorId", "") == request.auth.uid
      );
      allow list: if isAuth() && (
        isAdmin() ||
        resource.data.get("campanhaId", "") == myCampanha() ||
        resource.data.get("gabineteId", "") == myCampanha() ||
        resource.data.get("assessorId", "") == request.auth.uid ||
        resource.data.get("coordenadorId", "") == request.auth.uid
      );
      allow create: if isAuth() && (
        isAdmin() ||
        request.auth.uid == uid ||
        (
          me().get("role", "") == "coordenador" &&
          request.resource.data.get("status", "") == "pendente" &&
          request.resource.data.get("coordenadorId", "") == request.auth.uid &&
          request.resource.data.get("campanhaId", "") == myCampanha()
        ) ||
        // assessor_executivo pode criar assessores scoped à própria campanha
        (
          me().get("role", "") == "assessor_executivo" &&
          request.resource.data.get("role", "") in ["assessor", "coordenador"] &&
          request.resource.data.get("campanhaId", "") == myCampanha() &&
          request.resource.data.get("campanhaId", "") != ""
        )
      );
      allow update: if isAuth() && (
        (request.auth.uid == uid &&
         !request.resource.data.diff(resource.data).affectedKeys().hasAny(camposProtegidosSelf())) ||
        isAdmin() ||
        (me().get("role", "") in ["assessor_executivo", "assessor"] && (
          resource.data.get("campanhaId", "") == myCampanha() ||
          resource.data.get("gabineteId", "") == myCampanha()
        ) &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(camposProtegidosAssessor())) ||
        // coordenador corrigindo e reenviando própria solicitação recusada
        (
          me().get("role", "") == "coordenador" &&
          resource.data.get("status", "") == "recusado" &&
          resource.data.get("coordenadorId", "") == request.auth.uid &&
          request.resource.data.get("status", "") == "pendente" &&
          request.resource.data.get("coordenadorId", "") == request.auth.uid &&
          request.resource.data.get("campanhaId", "") == myCampanha()
        )
      );
      allow delete: if isAuth() && (
        isAdmin() ||
        // assessor_executivo / assessor: exclui coordenadores e colaboradores da própria campanha
        (
          me().get("role", "") in ["assessor_executivo", "assessor"] &&
          resource.data.get("role", "") in ["coordenador", "colaborador"] &&
          (
            resource.data.get("campanhaId", "") == myCampanha() ||
            resource.data.get("gabineteId", "") == myCampanha()
          )
        ) ||
        // coordenador: exclui colaboradores que gerencia
        (
          me().get("role", "") == "coordenador" &&
          resource.data.get("role", "") == "colaborador" &&
          resource.data.get("coordenadorId", "") == request.auth.uid &&
          resource.data.get("campanhaId", "") == myCampanha()
        )
      );
    }

    // ─── eleitores (joia da coroa) ─────────────────────────────────────────────
    match /eleitores/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("campanhaId", "") == myCampanha() ||
        resource.data.get("colaboradorId", "") == request.auth.uid ||
        resource.data.get("coordenadorId", "") == request.auth.uid
      );
      allow create: if isAuth() && (
        isAdmin() ||
        // colaborador cadastra para si mesmo
        (request.resource.data.get("campanhaId", "") == myCampanha() &&
         request.resource.data.get("colaboradorId", "") == request.auth.uid) ||
        // coordenador cadastra vinculando a colaborador da sua equipe
        (me().get("role", "") == "coordenador" &&
         request.resource.data.get("campanhaId", "") == myCampanha() &&
         request.resource.data.get("coordenadorId", "") == request.auth.uid &&
         request.resource.data.get("colaboradorId", "") != "") ||
        // assessor cadastra vinculando a colaborador da campanha
        (me().get("role", "") == "assessor" &&
         request.resource.data.get("campanhaId", "") == myCampanha() &&
         request.resource.data.get("colaboradorId", "") != "")
      );
      allow update: if isAuth() && (
        isAdmin() ||
        (resource.data.get("campanhaId", "") == myCampanha() && (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] ||
          resource.data.get("colaboradorId", "") == request.auth.uid ||
          resource.data.get("coordenadorId", "") == request.auth.uid
        ))
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── metas ────────────────────────────────────────────────────────────────
    match /metas/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("gabineteId", "") == myCampanha() ||
        resource.data.get("campanhaId", "") == myCampanha() ||
        resource.data.get("colaboradorId", "") == request.auth.uid ||
        resource.data.get("coordenadorId", "") == request.auth.uid
      );
      allow create, update: if isAuth() && (
        isAdmin() ||
        (me().get("role", "") in ["assessor_executivo", "assessor", "coordenador"] && (
          request.resource.data.get("gabineteId", "") == myCampanha() ||
          request.resource.data.get("campanhaId", "") == myCampanha()
        ))
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── candidatos ───────────────────────────────────────────────────────────
    match /candidatos/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("gabineteId", "") == myCampanha() ||
        resource.data.get("campanhaId", "") == myCampanha()
      );
      allow create, update: if isAuth() && (
        isAdmin() ||
        (me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
         request.resource.data.get("gabineteId", "") == myCampanha())
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── missoes ──────────────────────────────────────────────────────────────
    match /missoes/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("campanhaId", "") == myCampanha()
      );
      allow create: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo"] &&
          request.resource.data.get("campanhaId", "") == myCampanha() &&
          request.resource.data.get("campanhaId", "") != ""
        )
      );
      allow update: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo"] &&
          resource.data.get("campanhaId", "") == myCampanha()
        ) ||
        (
          me().get("role", "") == "assessor" &&
          resource.data.get("campanhaId", "") == myCampanha() &&
          resource.data.get("responsavelId", "") == request.auth.uid
        )
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── assessorias ──────────────────────────────────────────────────────────
    match /assessorias/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("campanhaId", "") == myCampanha()
      );
      allow create: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
          request.resource.data.get("campanhaId", "") == myCampanha() &&
          request.resource.data.get("campanhaId", "") != "" &&
          request.resource.data.get("criadoPor", "") == request.auth.uid
        )
      );
      allow update: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
          resource.data.get("campanhaId", "") == myCampanha()
        )
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── coordenacoes ─────────────────────────────────────────────────────────
    match /coordenacoes/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("campanhaId", "") == myCampanha()
      );
      allow create: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
          request.resource.data.get("campanhaId", "") == myCampanha() &&
          request.resource.data.get("campanhaId", "") != "" &&
          request.resource.data.get("criadoPor", "") == request.auth.uid
        )
      );
      allow update: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
          resource.data.get("campanhaId", "") == myCampanha()
        )
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── memoriaMandato ───────────────────────────────────────────────────────
    match /memoriaMandato/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("campanhaId", "") == myCampanha()
      );
      allow create: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
          request.resource.data.get("campanhaId", "") == myCampanha() &&
          request.resource.data.get("campanhaId", "") != ""
        )
      );
      allow update: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") in ["politico", "assessor_executivo", "prefeito", "vereador", "assessor"] &&
          resource.data.get("campanhaId", "") == myCampanha() &&
          request.resource.data.get("campanhaId", "") == resource.data.get("campanhaId", "")
        )
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ─── atividades (log de auditoria) ────────────────────────────────────────
    match /atividades/{id} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.get("gabineteId", "") == myCampanha() ||
        resource.data.get("campanhaId", "") == myCampanha()
      );
      allow create: if isAuth() && (
        request.resource.data.get("campanhaId", "") == myCampanha() ||
        request.resource.data.get("gabineteId", "") == myCampanha()
      );
      allow update, delete: if isAuth() && isAdmin();
    }

    // ─── coleções administrativas (prefixo _) ─────────────────────────────────

    // Erros de runtime — gravados pelo ErrorBoundary client-side
    match /_erros/{id} {
      allow create: if isAuth();
      allow read, update, delete: if isAuth() && isAdmin();
    }

    // Solicitações de exclusão LGPD (Art. 18 — direito ao esquecimento)
    match /_solicitacoes_lgpd/{id} {
      allow create: if isAuth() && (
        isAdmin() ||
        request.resource.data.get("campanhaId", "") == myCampanha()
      );
      allow read: if isAuth() && (
        isAdmin() ||
        (
          me().get("role", "") == "assessor_executivo" &&
          resource.data.get("campanhaId", "") == myCampanha()
        )
      );
      allow update: if isAuth() && isAdmin();
      allow delete: if isAuth() && isAdmin();
    }
  }
}
